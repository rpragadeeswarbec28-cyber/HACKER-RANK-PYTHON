from collections import Counter

def solve():
    
    n = int(input())
    
    word_counts = {}
    
    for _ in range(n):
        word = input().strip()
        if word in word_counts:
            word_counts[word] += 1
        else:
            word_counts[word] = 1
            
    print(len(word_counts))
    
    print(*(word_counts.values()))

if __name__ == '__main__':
    solve()
